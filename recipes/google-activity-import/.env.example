# Your Supabase project URL (from your Open Brain setup)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Your Supabase service role key (from Project Settings → API)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# OpenRouter API key — used for LLM day-summarization (NOT embeddings anymore)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Embeddings: self-hosted TEI (BAAI/bge-small-en-v1.5, 384-d). Defaults to the
# mini over Tailscale (no API key needed); override if needed.
# EMBED_BASE_URL=http://mac-mini-bruce:8080/v1
# EMBED_MODEL=BAAI/bge-small-en-v1.5

# Path to your extracted Google Takeout folder
# (the folder containing "My Activity" subdirectories)
GOOGLE_TAKEOUT_PATH=./Takeout/My Activity
