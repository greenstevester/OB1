# Open Brain credentials
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Embeddings: self-hosted TEI (BAAI/bge-small-en-v1.5, 384-d) via its
# OpenAI-compatible /v1/embeddings endpoint. The defaults below work when the
# recipe runs from a machine that can reach the mini over Tailscale; no API key
# is needed. On the mini itself, use http://localhost:8080/v1.
# EMBED_BASE_URL=http://mac-mini-bruce:8080/v1
# EMBED_MODEL=BAAI/bge-small-en-v1.5
