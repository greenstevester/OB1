SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Secret Key from Supabase dashboard (Settings → API → Secret key, starts with sb_secret_)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key-here

# OpenRouter (for LLM summarization — embeddings now come from self-hosted TEI)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Embeddings: self-hosted TEI (BAAI/bge-small-en-v1.5, 384-d). Defaults to the
# mini over Tailscale (no API key needed).
# EMBED_BASE_URL=http://mac-mini-bruce:8080/v1
# EMBED_MODEL=BAAI/bge-small-en-v1.5
